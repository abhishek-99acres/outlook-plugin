<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0" xsi:type="MailApp">

  <Id>a1b2c3d4-0000-4f59-883a-f6fff90e5dcc</Id>
  <Version>1.0.1.0</Version>
  <ProviderName>99Acres</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Attachment Categorizer"/>
  <Description DefaultValue="Categorizes attachments for specific recipients"/>
  <IconUrl DefaultValue="https://abhishek-99acres.github.io/outlook-plugin/assets/icon-64.png"/>
  <HighResolutionIconUrl DefaultValue="https://abhishek-99acres.github.io/outlook-plugin/assets/icon-128.png"/>
  <SupportUrl DefaultValue="https://99acres.com"/>
  <AppDomains>
    <AppDomain>https://abhishek-99acres.github.io</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Mailbox"/>
  </Hosts>
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.2"/>
    </Sets>
  </Requirements>
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://abhishek-99acres.github.io/outlook-plugin/taskpane.html"/>
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>
  <Permissions>ReadWriteItem</Permissions>
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit"/>
  </Rule>
  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">

      <Description resid="residAppDesc"/>
      <Requirements>
        <bt:Sets DefaultMinVersion="1.3">
          <bt:Set Name="Mailbox"/>
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">

          <Runtimes>
            <!-- Outlook Web, Mac, New Windows → loads commands.html which loads commands.js -->
            <Runtime resid="WebViewRuntime.Url">
              <!-- Classic Outlook Windows → loads commands.js directly -->
              <Override type="javascript" resid="JSRuntime.Url"/>
            </Runtime>
          </Runtimes>

          <DesktopFormFactor>
            <ExtensionPoint xsi:type="MessageComposeCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="msgComposeGroup">
                  <Label resid="GroupLabel"/>
                  <Control xsi:type="Button" id="msgComposeOpenPaneButton">
                    <Label resid="TaskPaneButton.Label"/>
                    <Supertip>
                      <Title resid="TaskPaneButton.Label"/>
                      <Description resid="TaskPaneButton.Tooltip"/>
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16"/>
                      <bt:Image size="32" resid="Icon.32x32"/>
                      <bt:Image size="80" resid="Icon.80x80"/>
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <SourceLocation resid="Taskpane.Url"/>
                      <SupportsPinning>true</SupportsPinning>
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>

            <ExtensionPoint xsi:type="LaunchEvent">
              <LaunchEvents>
                <LaunchEvent Type="OnNewMessageCompose" FunctionName="onNewMessageComposeHandler"/>
                <LaunchEvent Type="OnMessageAttachmentsChanged" FunctionName="onMessageAttachmentsChangedHandler"/>
                <LaunchEvent Type="OnMessageRecipientsChanged" FunctionName="onMessageRecipientsChangedHandler"/>
                <LaunchEvent Type="OnMessageSend" FunctionName="onMessageSendHandler" SendMode="SoftBlock"/>
              </LaunchEvents>
              <SourceLocation resid="WebViewRuntime.Url"/>
            </ExtensionPoint>
          </DesktopFormFactor>

        </Host>
      </Hosts>

      <Resources>
        <bt:Images>
          <bt:Image id="Icon.16x16" DefaultValue="https://abhishek-99acres.github.io/outlook-plugin/assets/icon-16.png"/>
          <bt:Image id="Icon.32x32" DefaultValue="https://abhishek-99acres.github.io/outlook-plugin/assets/icon-32.png"/>
          <bt:Image id="Icon.64x64" DefaultValue="https://abhishek-99acres.github.io/outlook-plugin/assets/icon-64.png"/>
          <bt:Image id="Icon.80x80" DefaultValue="https://abhishek-99acres.github.io/outlook-plugin/assets/icon-80.png"/>
          <bt:Image id="Icon.128x128" DefaultValue="https://abhishek-99acres.github.io/outlook-plugin/assets/icon-128.png"/>
        </bt:Images>
        <bt:Urls>
          <bt:Url id="WebViewRuntime.Url" DefaultValue="https://abhishek-99acres.github.io/outlook-plugin/commands.html"/>
          <bt:Url id="JSRuntime.Url" DefaultValue="https://abhishek-99acres.github.io/outlook-plugin/commands.js"/>
          <bt:Url id="Taskpane.Url" DefaultValue="https://abhishek-99acres.github.io/outlook-plugin/taskpane.html"/>
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="GroupLabel" DefaultValue="Attachment Categorizer"/>
          <bt:String id="TaskPaneButton.Label" DefaultValue="View Categories"/>
          <bt:String id="residAppDesc" DefaultValue="Auto-categorizes attachments based on recipients"/>
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="TaskPaneButton.Tooltip" DefaultValue="View and manage attachment categories"/>
        </bt:LongStrings>
      </Resources>

    </VersionOverrides>
  </VersionOverrides>
</OfficeApp>